//
//  This definition file describes the requests in SILGen's zone.
//
//===----------------------------------------------------------------------===//

SWIFT_REQUEST(SILGen, ASTLoweringRequest,
              std::unique_ptr<SILModule>(ASTLoweringDescriptor),
              Uncached, NoLocationInfo)
SWIFT_REQUEST(SILGen, ParseSILModuleRequest,
              std::unique_ptr<SILModule>(ASTLoweringDescriptor),
              Uncached, NoLocationInfo)
SWIFT_REQUEST(SILGen, SILFunctionBodyRequest,
              SILFunction *(SILDeclRef),
              Cached, NoLocationInfo)
SWIFT_REQUEST(SILGen, SILFunctionInterfaceRequest,
              SILFunction *(SILDeclRef),
              Cached, NoLocationInfo)
SWIFT_REQUEST(SILGen, CleanedSILFunctionRequest,
              SILFunction *(SILDeclRef),
              Cached, NoLocationInfo)
SWIFT_REQUEST(SILGen, DiagnosedSILFunctionRequest,
              SILFunction *(SILDeclRef),
              Cached, NoLocationInfo)
SWIFT_REQUEST(SILGen, CanonicalSILFunctionRequest,
              SILFunction *(SILDeclRef),
              Cached, NoLocationInfo)
SWIFT_REQUEST(SILGen, AuxiliaryDeclEmissionRequest,
              evaluator::SideEffect(AbstractFunctionDecl *),
              Cached, NoLocationInfo)
SWIFT_REQUEST(SILGen, ArgumentGeneratorsRequest,
              evaluator::SideEffect(AbstractFunctionDecl *),
              Cached, NoLocationInfo)
SWIFT_REQUEST(SILGen, CDeclThunkRequest,
              evaluator::SideEffect(AbstractFunctionDecl *),
              Cached, NoLocationInfo)
SWIFT_REQUEST(SILGen, DistributedThunkRequest,
              evaluator::SideEffect(AbstractFunctionDecl *),
              Cached, NoLocationInfo)
SWIFT_REQUEST(SILGen, BackDeploymentRequest,
              evaluator::SideEffect(AbstractFunctionDecl *),
              Cached, NoLocationInfo)
SWIFT_REQUEST(SILGen, SILDifferentiabilityWitnessRequest,
              SILDifferentiabilityWitness *(AbstractFunctionDecl *,
                                            DerivativeAttr *),
              Cached, NoLocationInfo)
